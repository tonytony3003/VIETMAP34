  MergerProvince: {fileID: 21300000, guid: 01bceaf5b7c64ed4597f93ed748ee6b2, type: 3}
  provinceImage1: {fileID: 21300000, guid: 29a22f481f54d09479eb3181ba7afa90, type: 3}
